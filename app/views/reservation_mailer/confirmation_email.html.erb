<h1>Reservation Confirmation</h1>

<p>Dear <%= @first_name %> <%= @last_name %>,</p>

<p>Thank you for your reservation!</p>

<h2>Reservation Details</h2>
<ul>
  <li><strong>Reservation Date:</strong> <%= @reservation_date %></li>
  <li><strong>Meal Period:</strong> <%= @meal_period %></li>
  <li><strong>Number of Guests:</strong> <%= @number_of_guest %></li>
  <li><strong>Email:</strong> <%= @email %></li>
  <li><strong>Mobile Number:</strong> <%= @mobile_number %></li>
  <li><strong>Price:</strong> $<%= @price %></li>
  <li><strong>Downpayment:</strong> $<%= @downpayment %></li>
  <li><strong>Total:</strong> $<%= @total %></li>
</ul>

<h2>Courses Selected</h2>
<ul>
  <% @courses.each do |course| %>
    <li><%= course %></li>
  <% end %>
</ul>

<p>If you have any questions or need to make changes to your reservation, please contact us.</p>
<p>If you want to cancel your reservation, please click the link below:</p>
<p>cancel reservation link of FE </p>
<p>Best regards,</p>
<p>Your Restaurant Team</p>