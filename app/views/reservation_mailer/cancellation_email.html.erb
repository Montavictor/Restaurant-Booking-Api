<div
  style="
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
      Helvetica, Arial, sans-serif;
    color: #374151;
    max-width: 600px;
    margin: 40px auto 0 auto;
    padding: 24px;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    text-align: center;
  "
>
  <!-- Logo -->
  <div style="margin-bottom: 24px">
    <img
      src="https://i.imgur.com/y1jxH6X.png"
      alt="Logo"
      style="max-width: 300px; height: auto; margin: 30px auto 0 auto"
    />
  </div>

  <h1 style="margin-bottom: 16px; line-height: 1.3; color: #374151">
    Reservation Cancelled
  </h1>

  <div style="text-align: left; line-height: 1.6; margin-top: 16px">
    <p style="font-weight: bold">Hello <%= @reservation.first_name %>,</p>
    <p>
      Your reservation for <%= @reservation.reservation_date.strftime("%B %d,
      %Y") %> (<%= @reservation.meal_period.capitalize %>) has been
      <strong>successfully cancelled</strong>.
    </p>
    <p>We hope to serve you again soon.</p>
    <p>
      If you have any questions or need further assistance, please feel free to
      contact us.
    </p>
    <p>Thank you for choosing us!</p>

    <p style="margin: 0">Best regards,</p>
    <p style="margin: 0"><strong>Mesa Privado Team</strong></p>
  </div>
</div>
