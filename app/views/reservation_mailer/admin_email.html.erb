<div
  style="
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
      Helvetica, Arial, sans-serif;
    color: #374151;
    max-width: 600px;
    margin: 40px auto 0 auto;
    padding: 24px;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    text-align: center;
  "
>
  <!-- Logo -->
  <div style="margin-bottom: 24px">
    <img
      src="https://i.imgur.com/y1jxH6X.png"
      alt="Logo"
      style="max-width: 300px; height: auto; margin: 30px auto 0 auto"
    />
  </div>

  <h1 style="margin-bottom: 16px; line-height: 1.3; color: #374151">
    New Reservation
  </h1>

  <h2
    style="
      margin-top: 24px;
      margin-bottom: 8px;
      line-height: 1.25;
      color: #f15623;
    "
  >
    Reservation Details
  </h2>
  <ul
    style="
      list-style-type: none;
      padding: 0;
      line-height: 1.6;
      text-align: left;
    "
  >
    <li><strong>Reservation Date:</strong> <%= @reservation_date %></li>
    <li><strong>Meal Period:</strong> <%= @meal_period %></li>
    <li><strong>Number of Guests:</strong> <%= @number_of_guest %></li>
    <li><strong>Email:</strong> <%= @email %></li>
    <li><strong>Mobile Number:</strong> <%= @mobile_number %></li>
    <li>
      <strong>Price:</strong>
      <%= number_to_currency(@price, unit: "₱", precision: 0, delimiter: ",") %>
    </li>
    <% if @downpayment.present? && @downpayment > 0 %>
    <li>
      <strong>Downpayment:</strong>
      <%= number_to_currency(@downpayment, unit: "₱", precision: 0, delimiter:
      ",") %>
    </li>
    <% else %>
    <li><strong>Payment:</strong> Full Payment</li>
    <% end %>
    <li>
      <strong>Total:</strong>
      <%= number_to_currency(@total, unit: "₱", precision: 0, delimiter: ",") %>
    </li>
  </ul>

  <h2
    style="
      margin-top: 24px;
      margin-bottom: 8px;
      line-height: 1.25;
      color: #f15623;
    "
  >
    Courses Selected
  </h2>
  <ul
    style="
      list-style-type: none;
      padding: 0;
      line-height: 1.6;
      text-align: left;
    "
  >
    <li>First Course: <strong><%= @first_course %></strong></li>
    <li>Second Course: <strong><%= @second_course %></strong></li>
    <li>Third Course: <strong><%= @third_course %></strong></li>
    <li>Fourth Course: <strong><%= @fourth_course %></strong></li>
    <li>Fifth Course: <strong><%= @fifth_course %></strong></li>
    <li>Sixth Course: <strong><%= @sixth_course %></strong></li>
    <li>Seventh Course: <strong><%= @seventh_course %></strong></li>
    <li>Eighth Course: <strong><%= @eighth_course %></strong></li>
    <li>Ninth Course: <strong><%= @ninth_course %></strong></li>
  </ul>
</div>
